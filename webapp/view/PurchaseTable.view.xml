<mvc:View
    controllerName="sap.ui5.project.controller.PurchaseTable"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:tnt="sap.tnt"
>
    <Table
        id="purchaseTable"
        items="{orders>/PurchaseOrders}"
        growing="true"
        growingScrollToLoad="true"
        growingThreshold="10"
        alternateRowColors="true"
        autoPopinMode="true"
    >
        <headerToolbar>
            <OverflowToolbar>
                <Title
                    text="{i18n>purchaseTableTitle}"
                    level="H2"
                />

                <ToolbarSpacer />

                <SearchField
                    width="18rem"
                    search=".onSearchPurchase"
                    placeholder="{i18n>purchasePlaceHolder}"
                >
                    <layoutData>
                        <OverflowToolbarLayoutData priority="Low" />
                    </layoutData>
                </SearchField>
                <MenuButton
                    text="Sort"
                    icon="sap-icon://sort"
                >
                    <menu>
                        <Menu itemSelected="onSortPurchase">
                            <MenuItem
                                text="PO Number (Ascending)"
                                key="poAsc"
                            />
                            <MenuItem
                                text="PO Number (Descending)"
                                key="poDesc"
                            />

                            <MenuItem
                                text="Supplier Name (A-Z)"
                                key="supplierAsc"
                            />

                            <MenuItem
                                text="Supplier Name (Z-A)"
                                key="supplierDesc"
                            />

                            <MenuItem
                                text="Total Cost (Low-High)"
                                key="costAsc"
                            />

                            <MenuItem
                                text="Total Cost (High-Low)"
                                key="costDesc"
                            />

                            <MenuItem
                                text="Status"
                                key="status"
                            />
                        </Menu>
                    </menu>
                </MenuButton>
                <Button
                    text="Export"
                    icon="sap-icon://excel-attachment"
                    press="onExportPurchase"
                />
                <Button
                    icon="sap-icon://add"
                    text="{i18n>addNewPurchaseBtnText}"
                    type="Emphasized"
                    press="onCreatePurchase"
                >
                    <layoutData>
                        <OverflowToolbarLayoutData
                            priority="Low"
                            moveToOverflow="true"
                        />
                    </layoutData>
                </Button>
            </OverflowToolbar>
        </headerToolbar>

        <columns>
            <Column importance="High">
                <Text text="{i18n>purchaseCol1Text}" />
            </Column>

            <Column
                importance="High"
                minScreenWidth="Tablet"
                demandPopin="true"
            >
                <Text text="{i18n>purchaseCol2Text}" />
            </Column>

            <Column
                hAlign="End"
                importance="Medium"
                minScreenWidth="Tablet"
                demandPopin="true"
            >
                <Text text="{i18n>purchaseCol3Text}" />
            </Column>

            <Column
                hAlign="Center"
                importance="Low"
                minScreenWidth="Desktop"
                demandPopin="true"
            >
                <Text text="{i18n>purchaseCol4Text}" />
            </Column>

            <Column
                hAlign="Center"
                importance="High"
            >
                <Text text="{i18n>purchaseCol5Text}" />
            </Column>
        </columns>

        <items>
            <ColumnListItem
                type="Navigation"
                press="onDetails"
                vAlign="Middle"
            >
                <cells>
                    <ObjectIdentifier title="{orders>PONumber}" />

                    <Text text="{orders>SupplierName}" />

                    <ObjectNumber
                        number="{
                            path: 'orders>TotalCost',
                            type: 'sap.ui.model.type.Float',
                            formatOptions: {
                                groupingEnabled: true,
                                minFractionDigits: 2,
                                maxFractionDigits: 2
                            }
                        }"
                        unit="{orders>Currency}"
                    />
                    <tnt:InfoLabel
                        text="{orders>Status}"
                        colorScheme="{path:'orders>Status', formatter:'.formatter.statusColor'}"
                    />

                    <HBox
                        justifyContent="Center"
                        alignItems="Center"
                        wrap="Wrap"
                    >
                        <Button
                            icon="sap-icon://edit"
                            type="Transparent"
                            press="onEditPurchase"
                        />

                        <Button
                            icon="sap-icon://delete"
                            type="Transparent"
                            press="onDeletePurchase"
                        />
                    </HBox>
                </cells>
            </ColumnListItem>
        </items>
    </Table>
</mvc:View>
