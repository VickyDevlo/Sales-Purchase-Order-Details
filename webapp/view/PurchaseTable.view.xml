<mvc:View
    controllerName="sap.ui5.project.controller.PurchaseTable"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:tnt="sap.tnt"
>

    <Table
        id="purchaseTable"
        items="{orders>/PurchaseOrders}"
        growing="true"
        growingScrollToLoad="true"
        growingThreshold="10"
        autoPopinMode="true"
    >

        <headerToolbar>
            <OverflowToolbar>

                <Title
                    text="{i18n>purchaseTableTitle}"
                    level="H2"
                />

                <ToolbarSpacer />

                <SearchField
                    width="18rem"
                    search=".onSearchPurchase"
                >
                    <layoutData>
                        <OverflowToolbarLayoutData
                            priority="Low"
                            moveToOverflow="true"
                        />
                    </layoutData>
                </SearchField>

                <Button
                    icon="sap-icon://add"
                    text="{i18n>addNewPurchaseBtnText}"
                    type="Emphasized"
                    press="onCreatePurchase"
                >
                    <layoutData>
                        <OverflowToolbarLayoutData
                            priority="Low"
                            moveToOverflow="true"
                        />
                    </layoutData>
                </Button>

            </OverflowToolbar>
        </headerToolbar>

        <columns>

            <Column importance="High">
                <Text text="{i18n>purchaseCol1Text}" />
            </Column>

            <Column
                importance="High"
                minScreenWidth="Tablet"
                demandPopin="true"
            >
                <Text text="{i18n>purchaseCol2Text}" />
            </Column>

            <Column
                hAlign="End"
                importance="Medium"
                minScreenWidth="Tablet"
                demandPopin="true"
            >
                <Text text="{i18n>purchaseCol3Text}" />
            </Column>

            <Column
                hAlign="Center"
                importance="Low"
                minScreenWidth="Desktop"
                demandPopin="true"
            >
                <Text text="{i18n>purchaseCol4Text}" />
            </Column>

            <Column
                hAlign="Center"
                importance="High"
            >
                <Text text="{i18n>purchaseCol5Text}" />
            </Column>

        </columns>

        <items>

            <ColumnListItem
                type="Navigation"
                press="onDetails"
                vAlign="Middle"
            >

                <cells>

                    <ObjectIdentifier
                        title="{orders>PONumber}"
                    />

                    <Text
                        text="{orders>SupplierName}"
                    />

                    <ObjectNumber
                        number="{orders>TotalCost}"
                        unit="{orders>Currency}"
                    />

                    <tnt:InfoLabel
                        text="{orders>Status}"
                        colorScheme="{path:'orders>Status', formatter:'.formatter.statusColor'}"
                    />

                    <HBox
                        justifyContent="Center"
                        alignItems="Center"
                        wrap="Wrap"
                    >
                        <Button
                            icon="sap-icon://edit"
                            type="Transparent"
                            press="onEditPurchase"
                        />

                        <Button
                            icon="sap-icon://delete"
                            type="Transparent"
                            press="onDeletePurchase"
                        />
                    </HBox>

                </cells>

            </ColumnListItem>

        </items>

    </Table>

</mvc:View>