<mvc:View
    controllerName="sap.ui5.project.controller.SalesTable"
    xmlns='sap.m'
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:tnt="sap.tnt"
>
    <Table
        id="salesTable"
        items="{orders>/SalesOrders}"
        growing="true"
        growingThreshold="10"
        growingScrollToLoad="true"
        alternateRowColors="true"
        autoPopinMode="true"
    >
        <headerToolbar>
            <OverflowToolbar>
                <Title
                    text="{i18n>salesTableTitle}"
                    level="H2"
                />

                <ToolbarSpacer />

                <SearchField
                    width="18rem"
                    search=".onSearchSales"
                    placeholder="{i18n>salesPlaceHolder}"
                >
                    <layoutData>
                        <OverflowToolbarLayoutData priority="Low" />
                    </layoutData>
                </SearchField>
                <MenuButton
                    text="Sort"
                    icon="sap-icon://sort"
                >
                    <menu>
                        <Menu itemSelected="onSortSales">
                            <MenuItem
                                text="Order ID (Ascending)"
                                key="orderAsc"
                            />
                            <MenuItem
                                text="Order ID (Descending)"
                                key="orderDesc"
                            />

                            <MenuItem
                                text="Customer Name (A-Z)"
                                key="customerAsc"
                            />
                            <MenuItem
                                text="Customer Name (Z-A)"
                                key="customerDesc"
                            />

                            <MenuItem
                                text="Net Amount (Low-High)"
                                key="amountAsc"
                            />
                            <MenuItem
                                text="Net Amount (High-Low)"
                                key="amountDesc"
                            />

                            <MenuItem
                                text="Status"
                                key="status"
                            />
                        </Menu>
                    </menu>
                </MenuButton>

                <Button
                    icon="sap-icon://add"
                    text="{i18n>addNewSaleBtnText}"
                    type="Emphasized"
                    press="onCreateSales"
                >
                    <layoutData>
                        <OverflowToolbarLayoutData
                            priority="Low"
                            moveToOverflow="true"
                        />
                    </layoutData>
                </Button>
            </OverflowToolbar>
        </headerToolbar>

        <columns>
            <Column importance="High">
                <Text text="{i18n>salesCol1Text}" />
            </Column>

            <Column
                importance="High"
                minScreenWidth="Tablet"
                demandPopin="true"
            >
                <Text text="{i18n>salesCol2Text}" />
            </Column>

            <Column
                hAlign="End"
                importance="Medium"
                minScreenWidth="Tablet"
                demandPopin="true"
            >
                <Text text="{i18n>salesCol3Text}" />
            </Column>

            <Column
                hAlign="Center"
                importance="Low"
                minScreenWidth="Desktop"
                demandPopin="true"
            >
                <Text text="{i18n>salesCol4Text}" />
            </Column>

            <Column
                hAlign="Center"
                importance="High"
            >
                <Text text="{i18n>salesCol5Text}" />
            </Column>
        </columns>

        <items>
            <ColumnListItem
                type="Navigation"
                press="onDetails"
                vAlign="Middle"
            >
                <cells>
                    <ObjectIdentifier title="{orders>OrderID}" />

                    <Text text="{orders>CustomerName}" />

                    <ObjectNumber
                        number="{
                            path: 'orders>NetAmount',
                            type: 'sap.ui.model.type.Float',
                            formatOptions: {
                                groupingEnabled: true,
                                minFractionDigits: 2,
                                maxFractionDigits: 2
                            }
                        }"
                        unit="{orders>Currency}"
                    />

                    <tnt:InfoLabel
                        text="{orders>Status}"
                        colorScheme="{path:'orders>Status', formatter:'.formatter.statusColor'}"
                    />

                    <HBox
                        justifyContent="Center"
                        alignItems="Center"
                        wrap="Wrap"
                    >
                        <Button
                            icon="sap-icon://edit"
                            type="Transparent"
                            press="onEditSales"
                        />

                        <Button
                            icon="sap-icon://delete"
                            type="Transparent"
                            press="onDeleteSales"
                        />
                    </HBox>
                </cells>
            </ColumnListItem>
        </items>
    </Table>
</mvc:View>
