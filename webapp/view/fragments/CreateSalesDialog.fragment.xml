<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
>
    <Dialog
        id="idSalesDialog"
        title="{dialogData>/dialogTitle}"
        contentHeight="auto"
        draggable="true"
        resizable="true"
        type="Message"
    >
        <content>
            <VBox class="sapUiContentPadding">
                <!-- Header Fields -->
                <form:SimpleForm
                    editable="true"
                    layout="ResponsiveGridLayout"
                    title="{i18n>salesHeader}"
                >
                    <form:content>
                        <Label
                            text="{i18n>salesDialogLabel1}"
                            required="true"
                        />
                        <Input
                            id="inputSalesId"
                            enabled="false"
                        />
                        <Label
                            text="{i18n>salesDialogLabel2}"
                            required="true"
                        />
                        <Input
                            id="inputCustomerName"
                            placeholder="e.g. Horizon Ltd"
                            enabled="{dialogData>/someProperty}"
                        />
                        <Label text="{i18n>salesDialogLabel3}" />
                        <Select
                            id="selectStatus"
                            selectedKey="Pending"
                        >
                            <core:Item
                                key="Pending"
                                text="Pending"
                            />
                            <core:Item
                                key="In Progress"
                                text="In Progress"
                            />
                            <core:Item
                                key="Delivered"
                                text="Delivered"
                            />
                            <core:Item
                                key="Cancelled"
                                text="Cancelled"
                            />
                        </Select>
                    </form:content>
                </form:SimpleForm>

                <!-- Dynamic Item Row Entry Section -->
                <form:SimpleForm
                    editable="true"
                    layout="ResponsiveGridLayout"
                    title="{i18n>dialogFormTitle}"
                >
                    <form:content>
                        <Label
                            text="{i18n>dialogFormLabel1}"
                            required="true"
                        />
                        <Input
                            id="inputSalesProduct"
                            placeholder="e.g. Office Chair"
                        />
                        <Label
                            text="{i18n>dialogFormLabel2}"
                            required="true"
                        />
                        <HBox
                            wrap="Wrap"
                            alignItems="Center"
                        >
                            <Input
                                id="inputSalesQty"
                                type="Number"
                                placeholder="Qty"
                                width="8rem"
                                class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                            />

                            <Input
                                id="inputSalesPrice"
                                type="Number"
                                placeholder="Price"
                                width="10rem"
                                class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                            />

                            <Button
                                icon="sap-icon://add"
                                text="{i18n>dialogAddBtn}"
                                type="Emphasized"
                                press="onAddSalesItemRow"
                                class="sapUiTinyMarginBottom"
                            />
                        </HBox>
                    </form:content>
                </form:SimpleForm>

                <!-- Review Staged Items Table -->
                <Table
                    id="idStagedSalesTable"
                    items="{dialogData>/Items}"
                    noDataText="{i18n>dialogTableNoDataText}"
                    autoPopinMode="true"
                    growing="true"
                    growingThreshold="5"
                >
                    <columns>
                        <Column importance="High">
                            <Text text="{i18n>dialogTableCol1Text}" />
                        </Column>

                        <Column
                            hAlign="End"
                            importance="Medium"
                            minScreenWidth="Tablet"
                            demandPopin="true"
                        >
                            <Text text="{i18n>dialogTableCol2Text}" />
                        </Column>

                        <Column
                            hAlign="End"
                            importance="High"
                        >
                            <Text text="{i18n>dialogTableCol3Text}" />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{dialogData>Product}" />
                                <Text text="{dialogData>Quantity}" />
                                <ObjectNumber
                                    number="{
                                        path: 'dialogData>TotalPrice',
                                        type: 'sap.ui.model.type.Float',
                                        formatOptions: {
                                            groupingEnabled: true,
                                            minFractionDigits: 2,
                                            maxFractionDigits: 2
                                        }
                                    }"
                                    unit="{dialogData>/Currency}"
                                />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
        <beginButton>
            <Button
                text="{dialogData>/btnText}"
                type="Emphasized"
                press="onSaveSales"
            />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>dialogCancelBtn}"
                type="Reject"
                press="onCloseSalesDialog"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
