<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
>
    <Dialog
        id="idPurchaseDialog"
        title="{dialogData>/dialogTitle}"
        contentHeight="auto"
        draggable="true"
        resizable="true"
        type="Message"
    >
        <content>
            <VBox class="sapUiContentPadding">
                <!-- Header Fields -->
                <form:SimpleForm
                    editable="true"
                    layout="ResponsiveGridLayout"
                    title="{i18n>purchaseHeader}"
                >
                    <form:content>
                        <Label
                            text="{i18n>purchaseDialogLabel1}"
                            required="true"
                        />
                        <Input id="inputPOId" />
                        <Label
                            text="{i18n>purchaseDialogLabel2}"
                            required="true"
                        />
                        <Input
                            id="inputSupplierName"
                            placeholder="e.g. Nexus Logistics"
                            enabled="{dialogData>/someProperty}"
                        />
                        <Label text="{i18n>purchaseDialogLabel3}" />
                        <Select
                            id="selectPOStatus"
                            selectedKey="Pending"
                        >
                            <core:Item
                                key="Pending"
                                text="Pending"
                            />
                            <core:Item
                                key="In Progress"
                                text="In Progress"
                            />
                            <core:Item
                                key="Approved"
                                text="Approved"
                            />
                            <core:Item
                                key="Cancelled"
                                text="Cancelled"
                            />
                        </Select>
                    </form:content>
                </form:SimpleForm>

                <!-- Dynamic Item Row Entry Section -->
                <form:SimpleForm
                    editable="true"
                    title="{i18n>dialogFormTitle}"
                    layout="ResponsiveGridLayout"
                >
                    <form:content>
                        <Label
                            text="{i18n>dialogFormLabel1}"
                            required="true"
                        />
                        <Input
                            id="inputPOProduct"
                            placeholder="e.g. Raw Timber Spools"
                        />
                        <Label
                            text="{i18n>dialogFormLabel2}"
                            required="true"
                        />
                        <HBox
                            wrap="Wrap"
                            alignItems="Center"
                        >
                            <Input
                                id="inputPOQty"
                                type="Number"
                                placeholder="Qty"
                                width="8rem"
                                class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                            />

                            <Input
                                id="inputPOPrice"
                                type="Number"
                                placeholder="Price"
                                width="10rem"
                                class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                            />

                            <Button
                                icon="sap-icon://add"
                                text="{i18n>dialogAddBtn}"
                                type="Emphasized"
                                press="onAddPOItemRow"
                                class="sapUiTinyMarginBottom"
                            />
                        </HBox>
                    </form:content>
                </form:SimpleForm>

                <!-- Review Staged Items Table -->
                <Table
                    id="idStagedPOTable"
                    items="{dialogData>/Items}"
                    autoPopinMode="true"
                    growing="true"
                    growingThreshold="5"
                    noDataText="{i18n>dialogTableNoDataText}"
                >
                    <columns>
                        <Column importance="High">
                            <Text text="{i18n>dialogTableCol1Text}" />
                        </Column>

                        <Column
                            hAlign="End"
                            importance="Medium"
                            minScreenWidth="Tablet"
                            demandPopin="true"
                        >
                            <Text text="{i18n>dialogTableCol2Text}" />
                        </Column>

                        <Column
                            hAlign="End"
                            importance="High"
                        >
                            <Text text="{i18n>dialogTableCol3Text}" />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{dialogData>Product}" />
                                <Text text="{dialogData>Quantity}" />
                                <ObjectNumber
                                    number="{dialogData>TotalPrice}"
                                    unit="EUR"
                                />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
        <beginButton>
            <Button
                text="{dialogData>/btnText}"
                type="Emphasized"
                press="onSavePurchase"
            />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>dialogCancelBtn}"
                type="Reject"
                press="onClosePurchaseDialog"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>