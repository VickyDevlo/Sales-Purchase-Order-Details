<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
    xmlns:layout="sap.ui.layout"
>
    <Dialog
        id="idPurchaseDialog"
        title="{i18n>purchaseDialogTitle}"
        contentWidth="600px"
        type="Message"
    >
        <content>
            <VBox class="sapUiContentPadding">
                <!-- Header Fields -->
                <form:SimpleForm
                    editable="true"
                    layout="ResponsiveGridLayout"
                    title="{i18n>purchaseHeader}"
                >
                    <form:content>
                        <Label
                            text="{i18n>purchaseDialogLabel1}"
                            required="true"
                        />
                        <Input
                            id="inputPOId"
                            editable="false"
                        />
                        <Label
                            text="{i18n>purchaseDialogLabel2}"
                            required="true"
                        />
                        <Input
                            id="inputSupplierName"
                            placeholder="e.g. Nexus Logistics"
                        />
                        <Label text="{i18n>purchaseDialogLabel3}" />
                        <Select
                            id="selectPOStatus"
                            selectedKey="Pending"
                        >
                            <core:Item
                                key="Pending"
                                text="Pending"
                            />
                            <core:Item
                                key="In Progress"
                                text="In Progress"
                            />
                            <core:Item
                                key="Approved"
                                text="Approved"
                            />
                        </Select>
                    </form:content>
                </form:SimpleForm>

                <!-- Dynamic Item Row Entry Section -->
                <form:SimpleForm
                    editable="true"
                    layout="ResponsiveGridLayout"
                    title="{i18n>dialogFormTitle}"
                >
                    <form:content>
                        <Label
                            text="{i18n>dialogFormLabel1}"
                            required="true"
                        />
                        <Input
                            id="inputPOProduct"
                            placeholder="e.g. Raw Timber Spools"
                        />
                        <Label
                            text="{i18n>dialogFormLabel2}"
                            required="true"
                        />
                        <layout:HorizontalLayout>
                            <Input
                                id="inputPOQty"
                                type="Number"
                                placeholder="Qty"
                                width="100px"
                                class="sapUiTinyMarginEnd"
                            />
                            <Input
                                id="inputPOPrice"
                                type="Number"
                                placeholder="Price"
                                width="150px"
                            />
                            <Button
                                icon="sap-icon://add"
                                text="{i18n>dialogAddBtn}"
                                type="Ghost"
                                press="onAddPOItemRow"
                                class="sapUiTinyMarginBegin"
                            />
                        </layout:HorizontalLayout>
                    </form:content>
                </form:SimpleForm>

                <!-- Review Staged Items Table -->
                <Table
                    id="idStagedPOTable"
                    items="{dialogData>/Items}"
                    noDataText="{i18n>dialogTableNoDataText}"
                >
                    <columns>
                       
                        <Column width="45%">
                            <Text text="{i18n>dialogTableCol1Text}" />
                        </Column>
                        <Column
                            hAlign="End"
                            width="15%"
                        >
                            <Text text="{i18n>dialogTableCol2Text}" />
                        </Column>
                        <Column
                            hAlign="End"
                            width="25%"
                        >
                            <Text text="{i18n>dialogTableCol3Text}" />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells> 
                                <Text text="{dialogData>Product}" />
                                <Text text="{dialogData>Quantity}" />
                                <ObjectNumber
                                    number="{dialogData>TotalPrice}"
                                    unit="EUR"
                                />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
        <beginButton>
            <Button
                text="{i18n>dialogSaveBtn}"
                type="Emphasized"
                press="onSavePurchase"
            />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>dialogCancelBtn}"
                press="onClosePurchaseDialog"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
